		{
			"name": "Booking positive CRUD",
			"item": [
				{
					"name": "CreateBooking",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"",
									"const bookingSchema = {",
									"  type: \"object\",",
									"  required: [\"firstname\", \"lastname\", \"totalprice\", \"depositpaid\", \"bookingdates\"],",
									"  properties: {",
									"    firstname: { type: \"string\" },",
									"    lastname: { type: \"string\" },",
									"    totalprice: { type: \"number\" },",
									"    depositpaid: { type: \"boolean\" },",
									"    bookingdates: {",
									"      type: \"object\",",
									"      required: [\"checkin\", \"checkout\"],",
									"      properties: { checkin: { type: \"string\" }, checkout: { type: \"string\" } }",
									"    },",
									"    additionalneeds: { type: \"string\" }",
									"  }",
									"};",
									"const createResponseSchema = {",
									"  type: \"object\",",
									"  required: [\"bookingid\", \"booking\"],",
									"  properties: {",
									"    bookingid: { type: \"integer\" },",
									"    booking: bookingSchema",
									"  }",
									"};",
									"",
									"// Проверка времени ответа",
									"pm.test(\"Response time is under 2000ms\", function () {",
									"  pm.expect(pm.response.responseTime).to.be.below(2000);",
									"});",
									"",
									"// Проверка статус кода",
									"pm.test(\"Status code is 200\", function () {",
									"  pm.response.to.have.status(200);",
									"});",
									"",
									"// Проверка json схемы",
									"pm.test(\"Response matches create-booking schema\", function () {",
									"  pm.expect(pm.response.json()).to.have.jsonSchema(createResponseSchema);",
									"});",
									"",
									"// Проверка тело запроса",
									"pm.test(\"Returned booking matches the request body\", function () {",
									"  const json = pm.response.json();",
									"  pm.expect(json.booking.firstname).to.eql(\"Jim\");",
									"  pm.expect(json.booking.lastname).to.eql(\"Brown\");",
									"  pm.expect(json.booking.totalprice).to.eql(111);",
									"  pm.expect(json.booking.depositpaid).to.eql(true);",
									"  pm.expect(json.booking.bookingdates.checkin).to.eql(\"2024-01-01\");",
									"  pm.expect(json.booking.bookingdates.checkout).to.eql(\"2024-01-10\");",
									"});",
									"",
									"// Сохраняем booking_id",
									"const json = pm.response.json();",
									"pm.environment.set(\"booking_id\", json.bookingid);",
									"console.log(\"Saved booking_id =\", json.bookingid);"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
