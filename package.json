{
  "name": "the-internet-e2e",
  "version": "1.0.0",
  "description": "E2E autotests for the-internet.herokuapp.com — Playwright + Page Object Model + BDD",
  "scripts": {
    "test": "bddgen && playwright test",
    "test:e2e": "playwright test --project=e2e",
    "test:bdd": "bddgen && playwright test --project=bdd",
    "report": "playwright show-report"
  },
  "keywords": ["playwright", "e2e", "qa", "pom", "bdd", "gherkin"],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "1.55.0",
    "playwright-bdd": "^8.5.1",
    "typescript": "^5.7.0"
  }
}
